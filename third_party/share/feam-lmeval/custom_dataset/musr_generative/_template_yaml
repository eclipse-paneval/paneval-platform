dataset_path: TAUR-Lab/MuSR
output_type: generate_until
process_docs: !function utils.process_docs
doc_to_text: "{{prompt}}"
doc_to_target: "{{answer_index}}"
filter_list:
  - name: "custom-extract"
    filter:
      - function: "regex"
        regex_pattern: 'ANSWER: (\d+)'
      - function: "take_first"
generation_kwargs:
  until:
    - "</s>"
  do_sample: false
  temperature: 0.0
  max_gen_toks: 4096
metric_list:
  - metric: exact_match
    aggregation: mean
    higher_is_better: true
    ignore_case: true
    ignore_punctuation: true
metadata:
  version: 1.0
