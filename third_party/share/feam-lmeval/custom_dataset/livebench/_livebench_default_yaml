process_docs: !function utils.process_docs
output_type: generate_until
training_split: test
test_split: test
doc_to_text:  !function utils.doc_to_text
process_results: !function utils.process_results
doc_to_target: "{{task if ground_truth is undefined else ground_truth}}"
generation_kwargs:
  until:
    - "</s>"
  do_sample: false
  temperature: 0
  max_gen_toks: 4096
metric_list:
  - metric: exact_match
    aggregation: mean
    higher_is_better: true
num_fewshot: 0
metadata:
  version: 1.0
dataset_kwargs:
  trust_remote_code: true
