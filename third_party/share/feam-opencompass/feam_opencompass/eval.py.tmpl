tokenizer = environ.get('EVALUATION_MODEL_TOKENIZER')

if model_path.startswith(hugginface_prefix):
    model_path = model_path[len(hugginface_prefix):]
    models = [
        dict(
            type=HuggingFaceCausalLM,
            abbr=model_name,
            path=model_path,
            tokenizer_path=tokenizer or  model_path,
            tokenizer_kwargs=dict(
                trust_remote_code=True,
            ),
            max_out_len=int(max_seq_len / 2),
            max_seq_len=max_seq_len,
            batch_size=batch_size,
            model_kwargs=dict(trust_remote_code=True, device_map='auto'),
            generation_kwargs=dict(
                num_return_sequences=1,
                do_sample=True,
