# 接口前缀
VITE_API_BASEPATH=dev
VITE_API_BASE_URL=/api
VITE_UPLOAD_BASE_URL=/api/uploads
VITE_STATIC_BASE_URL=/
VITE_PRIVACY_URL=/privacy
VITE_ENABLE_ANALYTICS=false
VITE_DEPLOY_REGION=eu

# 打包路径
VITE_BASE_PATH=/dist-dev/

# 是否删除debugger
VITE_DROP_DEBUGGER=false

# 是否删除console.log
VITE_DROP_CONSOLE=false

# 是否sourcemap
VITE_SOURCEMAP=true

# 输出路径
VITE_OUT_DIR=dist-dev

# 标题
VITE_APP_TITLE=PanEval

# 是否使用在线图标
VITE_USE_ONLINE_ICON=true
